{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Noloong Profile Config",
  "type": "object",
  "properties": {
    "defaultProfileId": {
      "type": [
        "string",
        "null"
      ]
    },
    "profiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/RuntimeProfileConfig"
      }
    },
    "registryStore": {
      "anyOf": [
        {
          "$ref": "#/$defs/RegistryStoreConfig"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "profiles"
  ],
  "$defs": {
    "RuntimeProfileConfig": {
      "type": "object",
      "properties": {
        "profileId": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider": {
          "$ref": "#/$defs/BuiltInProviderConfig"
        },
        "eventStore": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProfileEventStoreConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "compaction": {
          "$ref": "#/$defs/ProfileCompactionConfig",
          "default": {
            "type": "auto"
          }
        },
        "plugins": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AgentPluginDeclaration"
          },
          "default": []
        },
        "manifestPatches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ManifestPatch"
          },
          "default": []
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "default": {}
        }
      },
      "required": [
        "profileId",
        "displayName",
        "provider"
      ]
    },
    "BuiltInProviderConfig": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "providerId": {
              "type": [
                "string",
                "null"
              ]
            },
            "model": {
              "type": "string"
            },
            "baseUrl": {
              "type": [
                "string",
                "null"
              ]
            },
            "apiKeyEnv": {
              "type": [
                "string",
                "null"
              ]
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {}
            },
            "extraBody": {
              "type": "object",
              "additionalProperties": true,
              "default": {}
            },
            "maxCompletionTokens": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint64",
              "minimum": 0
            },
            "reasoning": {
              "anyOf": [
                {
                  "$ref": "#/$defs/ChatCompletionsReasoningConfig"
                },
                {
                  "type": "null"
                }
              ]
            },
            "type": {
              "type": "string",
              "const": "chat_completions"
            }
          },
          "required": [
            "type",
            "model"
          ]
        },
        {
          "type": "object",
          "properties": {
            "providerId": {
              "type": [
                "string",
                "null"
              ]
            },
            "model": {
              "type": "string"
            },
            "baseUrl": {
              "type": [
                "string",
                "null"
              ]
            },
            "apiKeyEnv": {
              "type": [
                "string",
                "null"
              ]
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {}
            },
            "extraBody": {
              "type": "object",
              "additionalProperties": true,
              "default": {}
            },
            "maxOutputTokens": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint64",
              "minimum": 0
            },
            "stateMode": {
              "$ref": "#/$defs/ResponsesStateMode",
              "default": "stateless"
            },
            "reasoning": {
              "anyOf": [
                {
                  "$ref": "#/$defs/ResponsesProviderReasoningConfig"
                },
                {
                  "type": "null"
                }
              ]
            },
            "allowFileDataUrlInput": {
              "type": "boolean",
              "default": false
            },
            "type": {
              "type": "string",
              "const": "responses"
            }
          },
          "required": [
            "type",
            "model"
          ]
        },
        {
          "type": "object",
          "properties": {
            "providerId": {
              "type": [
                "string",
                "null"
              ]
            },
            "model": {
              "type": "string"
            },
            "baseUrl": {
              "type": [
                "string",
                "null"
              ]
            },
            "apiKeyEnv": {
              "type": [
                "string",
                "null"
              ]
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {}
            },
            "extraBody": {
              "type": "object",
              "additionalProperties": true,
              "default": {}
            },
            "maxTokens": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint64",
              "minimum": 0
            },
            "reasoning": {
              "anyOf": [
                {
                  "$ref": "#/$defs/AnthropicProviderReasoningConfig"
                },
                {
                  "type": "null"
                }
              ]
            },
            "type": {
              "type": "string",
              "const": "anthropic_messages"
            }
          },
          "required": [
            "type",
            "model"
          ]
        },
        {
          "type": "object",
          "properties": {
            "providerId": {
              "type": [
                "string",
                "null"
              ]
            },
            "model": {
              "type": "string"
            },
            "auth": {
              "$ref": "#/$defs/ChatGptAuthConfig",
              "default": {
                "type": "token_file"
              }
            },
            "stateMode": {
              "$ref": "#/$defs/ResponsesStateMode",
              "default": "stateless"
            },
            "reasoning": {
              "anyOf": [
                {
                  "$ref": "#/$defs/ResponsesProviderReasoningConfig"
                },
                {
                  "type": "null"
                }
              ]
            },
            "allowFileDataUrlInput": {
              "type": "boolean",
              "default": false
            },
            "type": {
              "type": "string",
              "const": "chatgpt_responses"
            }
          },
          "required": [
            "type",
            "model"
          ]
        }
      ]
    },
    "ChatCompletionsReasoningConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "effort": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChatCompletionsReasoningEffort"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "ChatCompletionsReasoningEffort": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "xhigh"
      ]
    },
    "ResponsesStateMode": {
      "type": "string",
      "enum": [
        "stateless",
        "stateful"
      ]
    },
    "ResponsesProviderReasoningConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "effort": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResponsesProviderReasoningEffort"
            },
            {
              "type": "null"
            }
          ]
        },
        "summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/ResponsesProviderReasoningSummary"
            },
            {
              "type": "null"
            }
          ]
        },
        "includeEncrypted": {
          "type": "boolean"
        }
      }
    },
    "ResponsesProviderReasoningEffort": {
      "type": "string",
      "enum": [
        "minimal",
        "low",
        "medium",
        "high",
        "xhigh"
      ]
    },
    "ResponsesProviderReasoningSummary": {
      "type": "string",
      "enum": [
        "auto",
        "concise",
        "detailed",
        "none"
      ]
    },
    "AnthropicProviderReasoningConfig": {
      "type": "object",
      "properties": {
        "effort": {
          "anyOf": [
            {
              "$ref": "#/$defs/AnthropicProviderReasoningEffort"
            },
            {
              "type": "null"
            }
          ]
        },
        "thinking": {
          "anyOf": [
            {
              "$ref": "#/$defs/AnthropicProviderThinkingMode"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "AnthropicProviderReasoningEffort": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "xhigh",
        "max"
      ]
    },
    "AnthropicProviderThinkingMode": {
      "type": "string",
      "enum": [
        "adaptive",
        "disabled",
        "omit"
      ]
    },
    "ChatGptAuthConfig": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "tokenFile": {
              "type": [
                "string",
                "null"
              ]
            },
            "tokenFileEnv": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "type": "string",
              "const": "token_file"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "headers": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/EnvHeaderConfig"
              }
            },
            "type": {
              "type": "string",
              "const": "env_headers"
            }
          },
          "required": [
            "type",
            "id",
            "headers"
          ]
        }
      ]
    },
    "EnvHeaderConfig": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "env": {
          "type": "string"
        },
        "valuePrefix": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name",
        "env"
      ]
    },
    "ProfileEventStoreConfig": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "memory"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "databaseUrl": {
              "type": "string"
            },
            "migrateOnConnect": {
              "type": "boolean",
              "default": true
            },
            "type": {
              "type": "string",
              "const": "sqlite"
            }
          },
          "required": [
            "type",
            "databaseUrl"
          ]
        }
      ]
    },
    "ProfileCompactionConfig": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "auto"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "none"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": [
                "string",
                "null"
              ]
            },
            "inputLimitModel": {
              "type": [
                "string",
                "null"
              ]
            },
            "compactModel": {
              "type": [
                "string",
                "null"
              ]
            },
            "inputLimitTokens": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint64",
              "minimum": 1
            },
            "triggerRatio": {
              "type": [
                "number",
                "null"
              ],
              "format": "double",
              "maximum": 1.0,
              "exclusiveMinimum": 0
            },
            "summaryBudgetTokens": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint64",
              "minimum": 1
            },
            "keepRecentTokens": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint64",
              "minimum": 1
            },
            "mode": {
              "anyOf": [
                {
                  "$ref": "#/$defs/ContextCompactionMode"
                },
                {
                  "type": "null"
                }
              ]
            },
            "requestTimeoutSecs": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint64",
              "minimum": 1
            },
            "type": {
              "type": "string",
              "const": "openai_responses"
            }
          },
          "required": [
            "type"
          ]
        }
      ]
    },
    "ContextCompactionMode": {
      "type": "string",
      "enum": [
        "persistent_state",
        "request_only"
      ]
    },
    "AgentPluginDeclaration": {
      "type": "object",
      "properties": {
        "pluginId": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginComponent"
          }
        },
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "onLoadFailure": {
          "$ref": "#/$defs/PluginLoadFailurePolicy",
          "default": "disable_for_run"
        }
      },
      "required": [
        "pluginId",
        "displayName",
        "components"
      ]
    },
    "PluginComponent": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "skills"
            }
          },
          "$ref": "#/$defs/SkillsPluginComponent",
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "mcp"
            }
          },
          "$ref": "#/$defs/McpPluginComponent",
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "noloong_extension"
            }
          },
          "$ref": "#/$defs/NoloongExtensionPluginComponent",
          "required": [
            "type"
          ]
        }
      ]
    },
    "SkillsPluginComponent": {
      "type": "object",
      "properties": {
        "roots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "roots"
      ]
    },
    "McpPluginTransport": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "stdio"
            }
          },
          "$ref": "#/$defs/McpStdioTransport",
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "streamable_http"
            }
          },
          "$ref": "#/$defs/McpStreamableHttpTransport",
          "required": [
            "type"
          ]
        }
      ]
    },
    "PluginEnvSource": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "host_env"
            }
          },
          "required": [
            "type",
            "name"
          ]
        }
      ]
    },
    "McpStdioTransport": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "cwd": {
          "type": [
            "string",
            "null"
          ]
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/PluginEnvSource"
          },
          "default": {}
        },
        "requestTimeoutSecs": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "command"
      ]
    },
    "McpHeaderSource": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "value": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "static"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "prefix": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "type": "string",
              "const": "host_env"
            }
          },
          "required": [
            "type",
            "name"
          ]
        }
      ]
    },
    "McpStreamableHttpTransport": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/McpHeaderSource"
          },
          "default": {}
        },
        "connectTimeoutSecs": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "requestTimeoutSecs": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "url"
      ]
    },
    "McpPluginComponent": {
      "type": "object",
      "properties": {
        "serverId": {
          "type": "string"
        },
        "transport": {
          "$ref": "#/$defs/McpPluginTransport"
        },
        "enabledTools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "disabledTools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "toolNamePrefix": {
          "type": [
            "string",
            "null"
          ]
        },
        "requestTimeoutSecs": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "serverId",
        "transport"
      ]
    },
    "NoloongExtensionTransport": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "stdio"
            }
          },
          "$ref": "#/$defs/StdioPluginTransport",
          "required": [
            "type"
          ]
        }
      ]
    },
    "StdioPluginTransport": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "cwd": {
          "type": [
            "string",
            "null"
          ]
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/PluginEnvSource"
          },
          "default": {}
        },
        "requestTimeoutSecs": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "streamTimeoutSecs": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "command"
      ]
    },
    "ExtensionCapabilitySelector": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "model_provider"
            }
          },
          "required": [
            "type",
            "id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "tool"
            }
          },
          "required": [
            "type",
            "name"
          ]
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "context_provider"
            }
          },
          "required": [
            "type",
            "id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "phase_node"
            }
          },
          "required": [
            "type",
            "id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "phase_hook"
            }
          },
          "required": [
            "type",
            "id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "tool_call_hook"
            }
          },
          "required": [
            "type",
            "id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "compaction_summarizer"
            }
          },
          "required": [
            "type",
            "id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "context_compactor"
            }
          },
          "required": [
            "type",
            "id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "http_auth_provider"
            }
          },
          "required": [
            "type",
            "id"
          ]
        }
      ]
    },
    "NoloongExtensionPluginComponent": {
      "type": "object",
      "properties": {
        "transport": {
          "$ref": "#/$defs/NoloongExtensionTransport"
        },
        "allowedCapabilities": {
