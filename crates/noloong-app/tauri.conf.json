{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noloong",
  "version": "0.1.0",
  "identifier": "com.noloong.desktop",
  "build": {
    "beforeDevCommand": "bun --cwd ../apps/desktop dev",
    "beforeBuildCommand": "bun --cwd ../apps/desktop build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../apps/desktop/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Noloong",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 680,
        "backgroundThrottling": "disabled",
        "backgroundColor": "#F7F3EA",
        "decorations": true,
        "closable": true,
        "minimizable": true,
        "maximizable": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "assets/noloong-logo.png",
      "assets/noloong-logo.icns"
    ]
  }
}
