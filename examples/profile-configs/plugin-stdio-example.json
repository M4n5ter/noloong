{
  "defaultProfileId": "plugin-stdio-example",
  "profiles": [
    {
      "profileId": "plugin-stdio-example",
      "displayName": "Plugin stdio example",
      "description": "Example profile that loads a Python stdio JSON-RPC extension as a product plugin.",
      "provider": {
        "type": "chat_completions",
        "model": "openrouter/free",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKeyEnv": "OPENROUTER_API_KEY"
      },
      "plugins": [
        {
          "pluginId": "python-conformance",
          "displayName": "Python conformance plugin",
          "description": "Loads the Python extension example and allows only its echo tool.",
          "enabled": true,
          "onLoadFailure": "disable_for_run",
          "transport": {
            "type": "stdio",
            "command": "python3",
            "args": [
              "examples/extensions/python-conformance/full_conformance_extension.py"
            ],
            "env": {
              "PATH": {
                "type": "host_env",
                "name": "PATH"
              }
            },
            "requestTimeoutSecs": 5,
            "streamTimeoutSecs": 30
          },
          "allowedCapabilities": [
            {
              "type": "tool",
              "name": "conformance_echo"
            }
          ]
        }
      ],
      "manifestPatches": [
        {
          "op": "set_locale",
          "locale": "zh"
        }
      ],
      "metadata": {
        "example": true,
        "pluginTransport": "stdio"
      }
    }
  ]
}
